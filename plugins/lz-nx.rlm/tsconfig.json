{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "emitDeclarationOnly": false,
    "rootDir": "scripts",
    "types": ["node"]
  },
  "include": ["scripts/**/*.mjs"],
  "exclude": ["node_modules"]
}
